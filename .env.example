# =============================================================
#  DIMSYS — Template Konfigurasi Environment
# -------------------------------------------------------------
#  Nilai default di file ini AMAN untuk PRODUCTION (VPS).
#  Untuk pengembangan LOKAL (Laragon), gunakan nilai yang
#  ditandai "# lokal:" pada komentar tiap baris.
#  Lihat DEPLOYMENT.md untuk panduan lengkap.
# =============================================================

APP_NAME=DIMSYS
APP_ENV=production              # lokal: local
APP_KEY=                        # WAJIB diisi: jalankan `php artisan key:generate`
APP_DEBUG=false                 # lokal: true  (JANGAN true di production!)
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://domain-anda.com # ganti dengan domain VPS Anda (pakai HTTPS)
                                # lokal Laragon: http://localhost/dimsys/public

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# ---- Logging ----
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                 # lokal: debug

# ---- Database ----
# WAJIB: di VPS pakai user khusus + password kuat, JANGAN root.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dimsys
DB_USERNAME=dimsys_user         # JANGAN pakai root di production
DB_PASSWORD=                    # isi password kuat

# ---- Session ----
# database = aman untuk VPS (tabel sessions sudah ada via migrasi).
SESSION_DRIVER=database         # lokal boleh: file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ---- Media bukti (foto/video STO & Pindah Stok) ----
# Disk privat: file TIDAK bisa diakses tanpa login (lihat MediaController).
MEDIA_DISK=media

# ---- Queue ----
# sync = proses langsung saat request (tidak butuh worker di VPS).
QUEUE_CONNECTION=sync           # lokal boleh: database
# DIMSYS tidak memakai konversi gambar berat → matikan agar tabel jobs
# tidak menumpuk job konversi yang tidak diproses.
QUEUE_CONVERSIONS_BY_DEFAULT=false

# ---- Cache ----
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---- Mail ----
# Default 'log' (email hanya ditulis ke log, TIDAK terkirim).
# Reset password DIMSYS dilakukan Admin via menu Master User,
# jadi SMTP TIDAK wajib. Aktifkan SMTP hanya bila ingin
# reset password lewat email. Isi placeholder di bawah lalu set
# MAIL_MAILER=smtp.
MAIL_MAILER=log
MAIL_HOST=smtp.domain-anda.com
MAIL_PORT=587
MAIL_USERNAME=                  # email akun SMTP
MAIL_PASSWORD=                  # password / app-password SMTP
MAIL_SCHEME=null
# MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@domain-anda.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Batas upload media (informasi; diatur di php.ini server) ----
# Video bukti hingga 100MB. Pastikan php.ini & web server mengizinkan
# (lihat DEPLOYMENT.md bagian "Setting Upload").

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
